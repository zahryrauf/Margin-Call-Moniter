{
  "version": 2,
  "builds": [
    {
      "src": "index.php",
      "use": "@vercel/php",
      "config": {
        "runtime": "php@8.2"
      }
    }
  ],
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}