{
  "version": 2,
  "builds": [
    {
      "src": "build-vercel.sh",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "",
        "buildCommand": "bash build-vercel.sh",
        "outputDirectory": "public"
      }
    }
  ],
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(css|js|images|assets)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}